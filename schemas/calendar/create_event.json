{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rdyai.co/schemas/calendar/create_event.json",
  "title": "create_event",
  "description": "Create a calendar event with title, time, location, attendees, and recurrence. Supports Google Calendar and Outlook-compatible fields.",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Event title/summary"
    },
    "start_time": {
      "type": "string",
      "format": "date-time",
      "description": "Event start time (ISO 8601)"
    },
    "end_time": {
      "type": "string",
      "format": "date-time",
      "description": "Event end time (ISO 8601)"
    },
    "all_day": {
      "type": "boolean",
      "default": false,
      "description": "Whether this is an all-day event"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Event date for all-day events (YYYY-MM-DD)"
    },
    "timezone": {
      "type": "string",
      "description": "IANA timezone (e.g. 'Asia/Hong_Kong', 'America/New_York')"
    },
    "location": {
      "type": "string",
      "description": "Event location (address or virtual meeting URL)"
    },
    "description": {
      "type": "string",
      "description": "Event description or agenda"
    },
    "attendees": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "email", "description": "Attendee email" },
          "optional": { "type": "boolean", "default": false, "description": "Whether attendance is optional" }
        },
        "required": ["email"]
      },
      "description": "Event attendees"
    },
    "recurrence": {
      "type": "string",
      "description": "RRULE recurrence string (e.g. 'FREQ=WEEKLY;BYDAY=MO,WE,FR')"
    },
    "reminders": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "method": { "type": "string", "enum": ["email", "popup"], "description": "Reminder method" },
          "minutes_before": { "type": "number", "minimum": 0, "description": "Minutes before event" }
        },
        "required": ["method", "minutes_before"]
      },
      "description": "Custom reminders"
    },
    "calendar_id": {
      "type": "string",
      "description": "Calendar ID (defaults to primary calendar)"
    },
    "visibility": {
      "type": "string",
      "enum": ["default", "public", "private", "confidential"],
      "description": "Event visibility"
    },
    "conference": {
      "type": "string",
      "enum": ["google_meet", "zoom", "teams", "none"],
      "description": "Auto-create video conference link"
    }
  },
  "required": ["title", "start_time", "end_time"]
}
