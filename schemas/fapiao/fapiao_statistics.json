{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rdyai.co/schemas/fapiao/fapiao_statistics.json",
  "title": "fapiao_statistics",
  "description": "Generate fapiao statistics and reports. Summarize issued amounts by period, type, and tax rate. Track remaining quota and usage against monthly/quarterly limits.",
  "type": "object",
  "properties": {
    "action": {
      "type": "string",
      "enum": ["summary", "quota_status", "tax_breakdown", "monthly_report"],
      "description": "Report type to generate"
    },
    "period_start": {
      "type": "string",
      "format": "date",
      "description": "Report period start date (YYYY-MM-DD)"
    },
    "period_end": {
      "type": "string",
      "format": "date",
      "description": "Report period end date (YYYY-MM-DD)"
    },
    "fapiao_type": {
      "type": "string",
      "enum": ["general", "special", "all"],
      "default": "all",
      "description": "Filter by fapiao type"
    },
    "group_by": {
      "type": "string",
      "enum": ["day", "week", "month", "quarter", "tax_rate", "buyer"],
      "default": "month",
      "description": "Grouping dimension for summary"
    },
    "year": {
      "type": "number",
      "description": "Year for monthly_report (e.g. 2026)"
    },
    "month": {
      "type": "number",
      "minimum": 1,
      "maximum": 12,
      "description": "Month for monthly_report (1-12)"
    }
  },
  "required": ["action"]
}
