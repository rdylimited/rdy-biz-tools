{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rdyai.co/schemas/fapiao/query_fapiao.json",
  "title": "query_fapiao",
  "description": "Query and retrieve issued fapiao records. Search by fapiao code/number, buyer, date range, or status. Returns fapiao details including items, amounts, and verification status.",
  "type": "object",
  "properties": {
    "action": {
      "type": "string",
      "enum": ["get", "list", "verify"],
      "description": "Operation: get single fapiao, list with filters, or verify authenticity"
    },
    "fapiao_id": {
      "type": "string",
      "description": "Internal fapiao ID (required for get)"
    },
    "fapiao_code": {
      "type": "string",
      "description": "Fapiao code (发票代码) for verification"
    },
    "fapiao_number": {
      "type": "string",
      "description": "Fapiao number (发票号码) for verification"
    },
    "buyer_tax_id": {
      "type": "string",
      "description": "Filter by buyer tax registration number"
    },
    "fapiao_type": {
      "type": "string",
      "enum": ["general", "special"],
      "description": "Filter by fapiao type"
    },
    "status": {
      "type": "string",
      "enum": ["issued", "voided", "red_letter"],
      "description": "Filter by status"
    },
    "date_from": {
      "type": "string",
      "format": "date",
      "description": "Start date filter (YYYY-MM-DD)"
    },
    "date_to": {
      "type": "string",
      "format": "date",
      "description": "End date filter (YYYY-MM-DD)"
    },
    "check_code": {
      "type": "string",
      "description": "Verification check code (校验码, last 6 digits, required for verify)"
    },
    "page": {
      "type": "number",
      "minimum": 1,
      "default": 1,
      "description": "Page number"
    },
    "limit": {
      "type": "number",
      "minimum": 1,
      "maximum": 100,
      "default": 25,
      "description": "Items per page"
    }
  },
  "required": ["action"]
}
