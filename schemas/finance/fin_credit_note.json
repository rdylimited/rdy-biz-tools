{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rdyai.co/schemas/finance/fin_credit_note.json",
  "title": "fin_credit_note",
  "description": "Create, retrieve, or list credit and debit notes against invoices or bills.",
  "type": "object",
  "properties": {
    "action": {
      "type": "string",
      "enum": ["create", "get", "list"],
      "description": "Operation to perform"
    },
    "id": {
      "type": "string",
      "description": "Credit/debit note UUID (required for get)"
    },
    "type": {
      "type": "string",
      "enum": ["credit", "debit"],
      "description": "Note type"
    },
    "invoice_id": {
      "type": "string",
      "description": "Invoice UUID to apply note against"
    },
    "bill_id": {
      "type": "string",
      "description": "Bill UUID to apply note against"
    },
    "amount": {
      "type": "string",
      "description": "Note amount as decimal string"
    },
    "currency": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3,
      "description": "ISO 4217 currency code"
    },
    "reason": {
      "type": "string",
      "description": "Reason for the credit/debit note"
    },
    "date": {
      "type": "string",
      "description": "Note date (YYYY-MM-DD)"
    },
    "type_filter": {
      "type": "string",
      "enum": ["credit", "debit"],
      "description": "Filter by note type (for list)"
    },
    "invoice_id_filter": {
      "type": "string",
      "description": "Filter by invoice UUID (for list)"
    },
    "bill_id_filter": {
      "type": "string",
      "description": "Filter by bill UUID (for list)"
    },
    "date_from": {
      "type": "string",
      "description": "Start date filter (YYYY-MM-DD)"
    },
    "date_to": {
      "type": "string",
      "description": "End date filter (YYYY-MM-DD)"
    },
    "page": {
      "type": "number",
      "minimum": 1,
      "default": 1,
      "description": "Page number"
    },
    "limit": {
      "type": "number",
      "minimum": 1,
      "maximum": 100,
      "default": 25,
      "description": "Items per page"
    }
  },
  "required": ["action"]
}
