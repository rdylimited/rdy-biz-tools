{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rdyai.co/schemas/finance/fin_payment_record.json",
  "title": "fin_payment_record",
  "description": "Record received or made payments with optional allocation to invoices or bills.",
  "type": "object",
  "properties": {
    "action": {
      "type": "string",
      "enum": ["create", "get", "list"],
      "description": "Operation to perform"
    },
    "id": {
      "type": "string",
      "description": "Payment UUID (required for get)"
    },
    "type": {
      "type": "string",
      "enum": ["received", "made"],
      "description": "Payment direction"
    },
    "contact_id": {
      "type": "string",
      "description": "Contact UUID (customer or supplier)"
    },
    "amount": {
      "type": "string",
      "description": "Payment amount as decimal string"
    },
    "currency": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3,
      "description": "ISO 4217 currency code"
    },
    "method": {
      "type": "string",
      "enum": ["bank_transfer", "cheque", "cash", "credit_card", "other"],
      "description": "Payment method"
    },
    "reference": {
      "type": "string",
      "description": "Payment reference number"
    },
    "date": {
      "type": "string",
      "description": "Payment date (YYYY-MM-DD)"
    },
    "allocated_to": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "document_type": {
            "type": "string",
            "enum": ["invoice", "bill"],
            "description": "Type of document to allocate against"
          },
          "document_id": {
            "type": "string",
            "description": "Document UUID"
          },
          "amount": {
            "type": "string",
            "description": "Allocated amount as decimal string"
          }
        },
        "required": ["document_type", "document_id", "amount"]
      },
      "description": "Payment allocation to invoices or bills"
    },
    "type_filter": {
      "type": "string",
      "enum": ["received", "made"],
      "description": "Filter by payment direction (for list)"
    },
    "contact_id_filter": {
      "type": "string",
      "description": "Filter by contact UUID (for list)"
    },
    "date_from": {
      "type": "string",
      "description": "Start date filter (YYYY-MM-DD)"
    },
    "date_to": {
      "type": "string",
      "description": "End date filter (YYYY-MM-DD)"
    },
    "page": {
      "type": "number",
      "minimum": 1,
      "default": 1,
      "description": "Page number"
    },
    "limit": {
      "type": "number",
      "minimum": 1,
      "maximum": 100,
      "default": 25,
      "description": "Items per page"
    }
  },
  "required": ["action"]
}
