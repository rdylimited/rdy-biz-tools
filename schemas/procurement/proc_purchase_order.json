{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rdyai.co/schemas/procurement/proc_purchase_order.json",
  "title": "proc_purchase_order",
  "description": "CRUD + send/receive/close/cancel purchase orders",
  "type": "object",
  "properties": {
    "action": {
      "type": "string",
      "enum": ["create", "get", "update", "list", "send", "receive", "close", "cancel"],
      "description": "The purchase order operation to perform"
    },
    "id": {
      "type": "string",
      "description": "Purchase order UUID"
    },
    "supplier_id": {
      "type": "string",
      "description": "Supplier UUID"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Purchase order date (YYYY-MM-DD)"
    },
    "expected_date": {
      "type": "string",
      "format": "date",
      "description": "Expected delivery date (YYYY-MM-DD)"
    },
    "currency": {
      "type": "string",
      "description": "Currency code (e.g. USD, HKD)"
    },
    "notes": {
      "type": "string",
      "description": "Additional notes"
    },
    "lines": {
      "type": "array",
      "description": "Purchase order line items",
      "items": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string",
            "description": "Line item description"
          },
          "quantity": {
            "type": "string",
            "description": "Quantity as decimal string"
          },
          "unit_price": {
            "type": "string",
            "description": "Unit price as decimal string"
          },
          "tax_rate": {
            "type": "string",
            "description": "Tax rate as decimal string"
          }
        },
        "required": ["description", "quantity", "unit_price"]
      }
    },
    "grn_id": {
      "type": "string",
      "description": "GRN UUID (for receive action)"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "sent", "partial", "received", "closed", "cancelled"],
      "description": "Current status of the purchase order"
    },
    "supplier_id_filter": {
      "type": "string",
      "description": "Filter by supplier UUID"
    },
    "date_from": {
      "type": "string",
      "format": "date",
      "description": "Filter start date (YYYY-MM-DD)"
    },
    "date_to": {
      "type": "string",
      "format": "date",
      "description": "Filter end date (YYYY-MM-DD)"
    },
    "page": {
      "type": "number",
      "description": "Page number for paginated results"
    },
    "limit": {
      "type": "number",
      "description": "Number of results per page"
    }
  },
  "required": ["action"]
}
