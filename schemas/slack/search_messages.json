{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rdyai.co/schemas/slack/search_messages.json",
  "title": "search_messages",
  "description": "Search Slack message history by query. Supports filtering by channel, user, date range, and sort order. Uses Slack search syntax.",
  "type": "object",
  "properties": {
    "query": {
      "type": "string",
      "description": "Search query (Slack search syntax, e.g. 'from:@alice in:#engineering has:link after:2026-01-01')"
    },
    "channel": {
      "type": "string",
      "description": "Filter to a specific channel ID or name"
    },
    "from_user": {
      "type": "string",
      "description": "Filter by sender user ID or display name"
    },
    "date_from": {
      "type": "string",
      "format": "date",
      "description": "Start date filter (YYYY-MM-DD)"
    },
    "date_to": {
      "type": "string",
      "format": "date",
      "description": "End date filter (YYYY-MM-DD)"
    },
    "sort": {
      "type": "string",
      "enum": ["score", "timestamp"],
      "default": "score",
      "description": "Sort results by relevance or recency"
    },
    "sort_dir": {
      "type": "string",
      "enum": ["asc", "desc"],
      "default": "desc",
      "description": "Sort direction"
    },
    "page": {
      "type": "number",
      "minimum": 1,
      "default": 1,
      "description": "Page number"
    },
    "limit": {
      "type": "number",
      "minimum": 1,
      "maximum": 100,
      "default": 20,
      "description": "Items per page"
    }
  },
  "required": ["query"]
}
