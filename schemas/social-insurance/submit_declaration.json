{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rdyai.co/schemas/social-insurance/submit_declaration.json",
  "title": "submit_declaration",
  "description": "Submit monthly social insurance and housing fund declarations to the local bureau. Batch declare contributions for all enrolled employees in a pay period.",
  "type": "object",
  "properties": {
    "action": {
      "type": "string",
      "enum": ["prepare", "submit", "get_status", "list_declarations"],
      "description": "Operation: prepare draft, submit to bureau, check status, or list history"
    },
    "declaration_id": {
      "type": "string",
      "description": "Declaration ID (required for get_status)"
    },
    "city": {
      "type": "string",
      "description": "City code for the declaration"
    },
    "period": {
      "type": "string",
      "description": "Declaration period (YYYY-MM)"
    },
    "employees": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "employee_id": { "type": "string", "description": "Internal employee ID" },
          "id_number": { "type": "string", "description": "National ID number (身份证号)" },
          "name": { "type": "string", "description": "Employee name" },
          "salary_base": { "type": "string", "description": "Contribution base amount" },
          "housing_fund_base": { "type": "string", "description": "Housing fund base (if different)" }
        },
        "required": ["employee_id", "id_number", "name", "salary_base"]
      },
      "description": "Employee contribution details (required for prepare/submit)"
    },
    "date_from": {
      "type": "string",
      "format": "date",
      "description": "Start date filter for list_declarations"
    },
    "date_to": {
      "type": "string",
      "format": "date",
      "description": "End date filter for list_declarations"
    },
    "page": {
      "type": "number",
      "minimum": 1,
      "default": 1,
      "description": "Page number"
    },
    "limit": {
      "type": "number",
      "minimum": 1,
      "maximum": 100,
      "default": 25,
      "description": "Items per page"
    }
  },
  "required": ["action"]
}
