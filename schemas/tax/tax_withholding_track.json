{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rdyai.co/schemas/tax/tax_withholding_track.json",
  "title": "tax_withholding_track",
  "description": "Track WHT records, generate certificates",
  "type": "object",
  "properties": {
    "action": {
      "type": "string",
      "enum": ["create", "get", "list", "generate_certificate"],
      "description": "The withholding tax operation to perform"
    },
    "id": {
      "type": "string",
      "description": "WHT record UUID"
    },
    "payment_id": {
      "type": "string",
      "description": "Associated payment UUID"
    },
    "tax_rate_id": {
      "type": "string",
      "description": "Tax rate UUID applied for withholding"
    },
    "gross_amount": {
      "type": "string",
      "description": "Gross payment amount as decimal string"
    },
    "wht_amount": {
      "type": "string",
      "description": "Withholding tax amount as decimal string"
    },
    "certificate_number": {
      "type": "string",
      "description": "WHT certificate number"
    },
    "date_from": {
      "type": "string",
      "format": "date",
      "description": "Filter start date (YYYY-MM-DD)"
    },
    "date_to": {
      "type": "string",
      "format": "date",
      "description": "Filter end date (YYYY-MM-DD)"
    },
    "page": {
      "type": "number",
      "description": "Page number for paginated results"
    },
    "limit": {
      "type": "number",
      "description": "Number of results per page"
    }
  },
  "required": ["action"]
}
