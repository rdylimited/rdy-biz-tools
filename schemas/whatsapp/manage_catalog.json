{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rdyai.co/schemas/whatsapp/manage_catalog.json",
  "title": "manage_catalog",
  "description": "Manage WhatsApp Business product catalog. Create, update, delete, and list products. Products can be shared in interactive messages and product list messages.",
  "type": "object",
  "properties": {
    "action": {
      "type": "string",
      "enum": ["create_product", "update_product", "delete_product", "list_products", "get_product"],
      "description": "Operation to perform"
    },
    "catalog_id": {
      "type": "string",
      "description": "Catalog ID (defaults to the business's primary catalog)"
    },
    "product_id": {
      "type": "string",
      "description": "Product retailer ID (required for update/delete/get)"
    },
    "name": {
      "type": "string",
      "maxLength": 200,
      "description": "Product name (required for create)"
    },
    "description": {
      "type": "string",
      "maxLength": 5000,
      "description": "Product description"
    },
    "price": {
      "type": "number",
      "minimum": 0,
      "description": "Product price in cents (e.g. 1999 = $19.99)"
    },
    "currency": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3,
      "description": "ISO 4217 currency code"
    },
    "image_url": {
      "type": "string",
      "format": "uri",
      "description": "Product image URL"
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Product page URL"
    },
    "availability": {
      "type": "string",
      "enum": ["in stock", "out of stock"],
      "description": "Product availability"
    },
    "retailer_id": {
      "type": "string",
      "description": "Custom retailer/SKU ID"
    },
    "page": {
      "type": "number",
      "minimum": 1,
      "default": 1,
      "description": "Page number"
    },
    "limit": {
      "type": "number",
      "minimum": 1,
      "maximum": 100,
      "default": 25,
      "description": "Items per page"
    }
  },
  "required": ["action"]
}
