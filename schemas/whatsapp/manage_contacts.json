{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rdyai.co/schemas/whatsapp/manage_contacts.json",
  "title": "manage_contacts",
  "description": "Manage WhatsApp Business contacts. Check if phone numbers are on WhatsApp, manage contact labels, and retrieve conversation profiles.",
  "type": "object",
  "properties": {
    "action": {
      "type": "string",
      "enum": ["check_numbers", "get_profile", "list_contacts", "add_label", "remove_label", "list_labels"],
      "description": "Operation to perform"
    },
    "phone_numbers": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Phone numbers in E.164 format (required for check_numbers)"
    },
    "contact_phone": {
      "type": "string",
      "description": "Contact phone in E.164 format (required for get_profile/add_label/remove_label)"
    },
    "label_id": {
      "type": "string",
      "description": "Label ID (required for add_label/remove_label)"
    },
    "label_name": {
      "type": "string",
      "description": "Label name (for creating labels via add_label if label_id is omitted)"
    },
    "label_color": {
      "type": "number",
      "minimum": 0,
      "maximum": 20,
      "description": "Label color index (0-20)"
    },
    "page": {
      "type": "number",
      "minimum": 1,
      "default": 1,
      "description": "Page number"
    },
    "limit": {
      "type": "number",
      "minimum": 1,
      "maximum": 100,
      "default": 25,
      "description": "Items per page"
    }
  },
  "required": ["action"]
}
