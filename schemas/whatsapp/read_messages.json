{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rdyai.co/schemas/whatsapp/read_messages.json",
  "title": "read_messages",
  "description": "Read and manage incoming WhatsApp messages. Mark messages as read, retrieve message details, and list conversation history with a contact.",
  "type": "object",
  "properties": {
    "action": {
      "type": "string",
      "enum": ["get", "list", "mark_read", "download_media"],
      "description": "Operation to perform"
    },
    "message_id": {
      "type": "string",
      "description": "Message ID (required for get/mark_read)"
    },
    "contact_phone": {
      "type": "string",
      "description": "Contact phone in E.164 format (required for list)"
    },
    "media_id": {
      "type": "string",
      "description": "Media ID to download (required for download_media)"
    },
    "date_from": {
      "type": "string",
      "format": "date",
      "description": "Start date filter (YYYY-MM-DD)"
    },
    "date_to": {
      "type": "string",
      "format": "date",
      "description": "End date filter (YYYY-MM-DD)"
    },
    "page": {
      "type": "number",
      "minimum": 1,
      "default": 1,
      "description": "Page number"
    },
    "limit": {
      "type": "number",
      "minimum": 1,
      "maximum": 100,
      "default": 25,
      "description": "Items per page"
    }
  },
  "required": ["action"]
}
